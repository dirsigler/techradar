---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RingBadge from '../../components/RingBadge.astro';
import MovedIndicator from '../../components/MovedIndicator.astro';
import { Icon } from 'astro-icon/components';
import config from 'virtual:techradar/config';
import type { GetStaticPaths } from 'astro';

const siteBase = import.meta.env.BASE_URL.replace(/\/+$/, '');
const base = `${siteBase}${config.basePath}/`;

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('technologies');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props as { entry: CollectionEntry<'technologies'> };
const { Content } = await render(entry);

// Extract segment slug from entry id (e.g., "cloud/aws" → "cloud")
const parts = entry.id.split('/');
const segmentSlug = parts.slice(0, -1).join('/');

// Look up segment info for breadcrumb
const segmentEntries = await getCollection('segments');
const segmentEntry = segmentEntries.find((s) => {
  const sSlug = s.id.replace(/\/index$/, '').replace(/^index$/, s.id);
  return sSlug === segmentSlug;
});
const segmentTitle = segmentEntry?.data.title ?? segmentSlug;
const segmentColor = segmentEntry?.data.color ?? '#6c7086';

// Build "Edit on GitHub" URL from the entry's file path
const techFileName = entry.id.split('/').pop();
const editUrl = config.editBaseUrl
  ? `${config.editBaseUrl}/${segmentSlug}/${techFileName}.md`
  : null;

const linkIconMap: Record<string, string> = {
  docs: 'lucide:book-open',
  repo: 'lucide:git-fork',
  website: 'lucide:globe',
  community: 'lucide:messages-square',
};
const linkOrder: Record<string, number> = { docs: 0, repo: 1, website: 2, community: 3 };
const links = (entry.data.links ?? [])
  .map((link: { label: string; url: string; type: string }) => ({
    ...link,
    icon: linkIconMap[link.type] ?? 'lucide:globe',
    order: linkOrder[link.type] ?? 99,
  }))
  .sort((a, b) => a.order - b.order);

const tags = (entry.data.tags ?? []) as string[];
const manualRelatedSlugs = (entry.data.related ?? []) as string[];

// Build related technologies: manual + auto (2+ shared tags)
const allTechnologies = await getCollection('technologies');
const manualRelated = manualRelatedSlugs
  .map((slug) => allTechnologies.find((t) => t.id === slug))
  .filter(Boolean);

const manualIds = new Set(manualRelatedSlugs);
manualIds.add(entry.id); // exclude self

let autoRelated: typeof manualRelated = [];
if (tags.length > 0) {
  autoRelated = allTechnologies.filter((t) => {
    if (manualIds.has(t.id)) return false;
    const otherTags = (t.data.tags ?? []) as string[];
    const shared = tags.filter((tag) => otherTags.includes(tag));
    return shared.length >= 2;
  });
}

const relatedTechnologies = [...manualRelated, ...autoRelated];
---

<Base title={`${entry.data.title} — Tech Radar`}>
  <nav class="mb-6 text-sm" style="color: var(--radar-text-faint);">
    <a href={base} class="breadcrumb-link">Tech Radar</a>
    <span class="mx-2">/</span>
    <a href={`${base}segments/${segmentSlug}/`} class="breadcrumb-link">
      {segmentTitle}
    </a>
    <span class="mx-2">/</span>
    <span style="color: var(--radar-text-secondary);">{entry.data.title}</span>
  </nav>

  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold flex items-center gap-3" style="color: var(--radar-text);">
        {entry.data.title}
        <MovedIndicator moved={entry.data.moved} />
      </h1>
      <div class="mt-3 flex items-center gap-3 flex-wrap">
        <RingBadge ring={entry.data.ring} />
        <span class="flex items-center gap-1.5 text-sm" style="color: var(--radar-text-muted);">
          <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background-color: ${segmentColor}`}></span>
          {segmentTitle}
        </span>
        {entry.data.owner && (
          <span class="flex items-center gap-1.5 text-sm" style="color: var(--radar-text-muted);">
            <Icon name="lucide:users-round" class="h-3.5 w-3.5" />
            {entry.data.owner.url ? (
              <a href={entry.data.owner.url} target="_blank" rel="noopener noreferrer" class="owner-link">
                {entry.data.owner.name}
              </a>
            ) : (
              entry.data.owner.name
            )}
          </span>
        )}
        {links.length > 0 && (
          <>
            <span class="meta-divider" />
            {links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="tech-link"
              >
                <Icon name={link.icon} class="h-3.5 w-3.5" />
                {link.label}
              </a>
            ))}
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-3 flex items-center gap-2 flex-wrap">
          {tags.map((tag) => (
            <a href={`${base}?tag=${encodeURIComponent(tag)}`} class="tag-pill">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>

    {entry.data.history && entry.data.history.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-semibold mb-4" style="color: var(--radar-text);">History</h2>
        <ol class="history-timeline">
          {[...entry.data.history].sort((a, b) => b.date.localeCompare(a.date)).map((h) => (
            <li class="history-entry">
              <div class="history-marker">
                <span class={`history-dot ring-${h.ring}`} />
                <span class="history-line" />
              </div>
              <div class="history-content">
                <div class="flex items-center gap-2 flex-wrap">
                  <RingBadge ring={h.ring} />
                  <time class="text-sm" style="color: var(--radar-text-faint);">{h.date}</time>
                </div>
                {h.description && (
                  <p class="mt-1 text-sm" style="color: var(--radar-text-muted);">{h.description}</p>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    {relatedTechnologies.length > 0 && (
      <div class="mt-8 text-sm" style="color: var(--radar-text-muted);">
        <span class="font-medium" style="color: var(--radar-text-secondary);">Related</span>
        {relatedTechnologies.map((tech, i) => (
          <>
            <span class="mx-1.5">{i > 0 ? '·' : ''}</span>
            <a href={`${base}technology/${tech.id}/`} class="related-link">{tech.data.title}</a>
          </>
        ))}
      </div>
    )}

    {editUrl && (
      <div class="mt-8 pt-6" style="border-top: 1px solid var(--radar-border);">
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="edit-link"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
          Edit this page
        </a>
      </div>
    )}
  </article>
</Base>

<style>
  .breadcrumb-link {
    color: var(--radar-text-faint);
    transition: color 0.15s;
  }
  .breadcrumb-link:hover {
    color: var(--radar-text-secondary);
  }

  .edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--radar-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .edit-link:hover {
    color: var(--radar-link);
  }

  .owner-link {
    color: var(--radar-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .owner-link:hover {
    color: var(--radar-link);
  }

  .meta-divider {
    width: 1px;
    height: 1rem;
    background-color: var(--radar-border);
  }

  .tech-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--radar-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .tech-link:hover {
    color: var(--radar-link);
  }

  .tag-pill {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    border: 1px solid var(--radar-border-subtle);
    font-size: 0.75rem;
    color: var(--radar-text-muted);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .tag-pill:hover {
    color: var(--radar-link);
    border-color: var(--radar-link);
  }

  .related-link {
    color: var(--radar-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .related-link:hover {
    color: var(--radar-link);
  }

  .history-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .history-entry {
    display: flex;
    gap: 0.75rem;
    position: relative;
  }

  .history-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 1rem;
  }

  .history-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
    flex-shrink: 0;
    margin-top: 0.375rem;
  }

  .history-dot.ring-adopt { background-color: var(--radar-ring-adopt); }
  .history-dot.ring-trial { background-color: var(--radar-ring-trial); }
  .history-dot.ring-assess { background-color: var(--radar-ring-assess); }
  .history-dot.ring-hold { background-color: var(--radar-ring-hold); }

  .history-line {
    flex: 1;
    width: 2px;
    background-color: var(--radar-border, #e2e8f0);
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .history-entry:last-child .history-line {
    display: none;
  }

  .history-content {
    padding-bottom: 1.25rem;
  }

  .history-entry:last-child .history-content {
    padding-bottom: 0;
  }
</style>
